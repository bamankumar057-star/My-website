<!DOCTYPE html>
<html>
<head>
    <title>Bharat Portfolio</title>

    <style>
        body {
            font-family: Arial;
            background: linear-gradient(to right, #74ebd5, #9face6);
            text-align: center;
            margin: 0;
        }

        .container {
            padding: 20px;
        }

        img {
            width: 120px;
            border-radius: 50%;
            margin-top: 20px;
        }

        .box {
            background: white;
            margin: 20px auto;
            padding: 20px;
            width: 80%;
            border-radius: 15px;
            box-shadow: 0 0 10px gray;
        }

        h1 {
            color: white;
        }

        button {
            padding: 10px 20px;
            border: none;
            background: darkblue;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: black;
        }
    </style>

</head>

<body>

    <div class="container">
        <img src="https://via.placeholder.com/120" alt="profile">

        <h1>Hello, I'm Bharat 👋</h1>

        <div class="box">
            <h2>About Me</h2>
            <p>I am learning coding and want to build my career in IT.</p>
        </div>

        <div class="box">
            <h2>Skills</h2>
            <p>Python, HTML, CSS (Learning)</p>
        </div>

        <div class="box">
            <h2>Contact</h2>
            <p>Email: example@gmail.com</p>
            <button onclick="showMessage()">Click Me</button>
        </div>
    </div>

    <script>
        function showMessage() {
            alert("Thanks for visiting my website 😊");
        }
    </script>

</body>
</html>
